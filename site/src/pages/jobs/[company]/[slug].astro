---
import { existsSync, readFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { marked } from "marked";

import Base from "../../../layouts/Base.astro";
import {
  boredCvLink,
  companies,
  countryName,
  formatDate,
  jobs,
  jobUrlPath,
  whereByJobId,
} from "../../../lib/data";

export async function getStaticPaths() {
  return jobs.map((j) => {
    const path = jobUrlPath(j); // "<company>/<title-slug>-<id8>"
    const [company, ...rest] = path.split("/");
    const slug = rest.join("/");
    return { params: { company, slug }, props: { jobId: j.id } };
  });
}

const { jobId } = Astro.props as { jobId: string };
const job = jobs.find((j) => j.id === jobId);
if (!job) throw new Error(`Job ${jobId} not found`);
const company = companies[job.company_slug];
const companyName = company?.name || job.company_slug;
const country = company ? countryName(company.country) : "";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

// Read the per-job description from disk at build time. The file is
// written by site/scripts/parquet-to-json.mjs from the parquet
// description_md column. ~15k tiny files, one read per page render →
// no in-memory big JSON.
const __dirname = dirname(fileURLToPath(import.meta.url));
const descPath = join(
  __dirname,
  "..",
  "..",
  "..",
  "..",
  "data-cache",
  "descriptions",
  `${jobId}.md`,
);
const descriptionMd = existsSync(descPath) ? readFileSync(descPath, "utf8") : "";

// GitHub-flavored markdown, no autolink IDs (cleaner output).
marked.setOptions({ gfm: true, breaks: false } as any);
const descriptionHtml = descriptionMd ? (marked.parse(descriptionMd) as string) : "";

// Schema.org JobPosting structured data — Google + LinkedIn pick this up.
const canonicalUrl = `https://aramente.github.io${base}jobs/${jobUrlPath(job)}/`;
const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  title: job.title,
  description: descriptionHtml || job.title,
  datePosted: job.posted_at || undefined,
  hiringOrganization: {
    "@type": "Organization",
    name: companyName,
    sameAs: company?.career_url || undefined,
  },
  jobLocation: job.location
    ? {
        "@type": "Place",
        address: { "@type": "PostalAddress", addressLocality: job.location },
      }
    : undefined,
  applicantLocationRequirements:
    job.remote_policy === "remote-eu"
      ? { "@type": "Country", name: "Europe" }
      : undefined,
  jobLocationType:
    job.remote_policy && job.remote_policy.startsWith("remote")
      ? "TELECOMMUTE"
      : undefined,
  url: canonicalUrl,
  directApply: false,
};

// Pagefind facet values. Pagefind reads `data-pagefind-meta` attributes on
// the indexed page and exposes them as filterable facets in the search UI.
//
// `where`: a unified location/remote facet so a multi-select like
// {France, Remote-EU, Remote-Worldwide} gives an OR across locations and
// remote tiers in one click — matches the "I can work in France OR
// remote, NOT Germany" use case directly. Onsite/hybrid jobs surface as
// the country code (e.g. "FR"); remote-eu / remote-global jobs surface
// under the corresponding "Remote — …" label.
const COUNTRY_NAMES: Record<string, string> = {
  FR: "France", DE: "Germany", GB: "United Kingdom", ES: "Spain",
  IT: "Italy", NL: "Netherlands", BE: "Belgium", SE: "Sweden",
  DK: "Denmark", FI: "Finland", NO: "Norway", IE: "Ireland",
  PT: "Portugal", PL: "Poland", CZ: "Czechia", AT: "Austria",
  CH: "Switzerland", EE: "Estonia", LT: "Lithuania", LV: "Latvia",
  GR: "Greece", RO: "Romania", BG: "Bulgaria", HU: "Hungary",
  SK: "Slovakia", SI: "Slovenia", HR: "Croatia", LU: "Luxembourg",
  IS: "Iceland", CY: "Cyprus", MT: "Malta",
  US: "United States", CA: "Canada", IL: "Israel", UA: "Ukraine",
  XX: "Remote / unknown",
};

// `where` is derived at build time in parquet-to-json.mjs — using the
// same enriched logic (city/country lookup in job.location, then company
// HQ, then remote_policy) so home-page facet counts match per-job filter.
const whereFacet: string = whereByJobId[jobId] || "Other";

// Synonym blob added INSIDE data-pagefind-body so role-family-driven
// queries match jobs even when the title doesn't carry the exact words.
// Without this, "talent acquisition" only matches titles that contain
// the literal phrase — but most HR roles are called "Recruiter" or
// "People Partner", and those should also surface for that query.
const ROLE_SYNONYMS: Record<string, string> = {
  hr: "HR Human Resources Recruiter Recruitment Recruiting Talent Acquisition People Operations People Partner Talent Partner Hiring",
  engineering: "Engineer Software Backend Frontend Full Stack Developer Programmer Coder",
  "ml-ai": "Machine Learning Artificial Intelligence ML AI Data Science Researcher MLOps LLM",
  data: "Data Analyst Analytics BI Business Intelligence Data Engineer Data Scientist",
  product: "Product Manager PM Owner Product Marketing Strategy",
  design: "Designer UX UI Visual Brand Product Designer Graphic",
  marketing: "Marketing Growth Brand Content SEO SEM Demand Generation Performance",
  sales: "Sales Account Executive AE Account Manager BDR SDR Business Development Customer Success Partnerships",
  ops: "Operations Ops Project Program Manager PMO Coordinator Administrator",
  finance: "Finance Accounting Controller FP&A Treasurer Tax Audit",
  legal: "Legal Counsel Compliance Privacy Regulatory Lawyer Paralegal",
  support: "Support Customer Service Technical Support Helpdesk Onboarding",
  research: "Research Scientist Researcher PhD Scientific R&D",
};
const synonymBlob = ROLE_SYNONYMS[job.role_family || ""] || "";
const senSyn =
  job.seniority === "lead" ? "Lead Principal Staff Director Head"
  : job.seniority === "senior" ? "Senior Sr"
  : job.seniority === "junior" ? "Junior Jr Entry Graduate Grad"
  : job.seniority === "mid" ? "Mid-level Mid"
  : "";
const indexedSynonyms = [synonymBlob, senSyn].filter(Boolean).join(" ");
---
<Base
  title={`${job.title} — ${companyName}`}
  description={`${job.title} at ${companyName} (${job.location || "remote"})`}
>
  <main>
    <p class="job-back">
      <a href={base} id="back-link" data-base={base}>← all jobs</a>
    </p>
    <article class="job">
      {/* Pagefind body restricted to the title block: searches like
          "talent acquisition" must match the job title, not text buried
          in the description (which would surface unrelated sales jobs
          that happen to mention "partner with talent acquisition"). */}
      <div data-pagefind-body>
        <span data-pagefind-filter={`where:${whereFacet}`} hidden></span>
        {job.role_family && (
          <span data-pagefind-filter={`role:${job.role_family}`} hidden></span>
        )}
        {job.remote_policy && (
          <span data-pagefind-filter={`remote:${job.remote_policy}`} hidden></span>
        )}
        <span data-pagefind-filter={`type:${job.employment_type || "permanent"}`} hidden></span>
        <span data-pagefind-meta={`company:${companyName}`} hidden></span>
        {country && <span data-pagefind-meta={`country:${country}`} hidden></span>}
        {job.location && <span data-pagefind-meta={`location:${job.location}`} hidden></span>}
        {job.posted_at && <span data-pagefind-meta={`posted:${job.posted_at.slice(0, 10)}`} hidden></span>}
        <span data-pagefind-meta={`where:${whereFacet}`} hidden></span>
        {job.remote_policy && <span data-pagefind-meta={`remote:${job.remote_policy}`} hidden></span>}
        {job.role_family && <span data-pagefind-meta={`role:${job.role_family}`} hidden></span>}
        {job.seniority && <span data-pagefind-meta={`seniority:${job.seniority}`} hidden></span>}
        <span data-pagefind-meta={`source:${job.source}`} hidden></span>
        <h1>{job.title}</h1>
        {indexedSynonyms && (
          <p class="visually-hidden">{indexedSynonyms}</p>
        )}
      </div>
      <p class="meta job-meta">
        <a href={`${base}companies/${job.company_slug}/`}>{companyName}</a>
        {country && <> · {country}</>}
        {job.location && <> · {job.location}</>}
        {job.posted_at && <> · posted {formatDate(job.posted_at)}</>}
        {job.role_family && (
          <> · <span class="badge">{job.role_family}</span></>
        )}
        {job.seniority && (
          <> · <span class="badge">{job.seniority}</span></>
        )}
        {job.remote_policy && (
          <> · <span class="badge">{job.remote_policy}</span></>
        )}
      </p>

      {descriptionHtml ? (
        <div class="job-description" data-pagefind-ignore set:html={descriptionHtml} />
      ) : (
        <div class="job-description-fallback" data-pagefind-ignore>
          <p>
            Full description not mirrored on this page. Click <em>Apply</em> below for the full posting on {companyName}'s site.
          </p>
        </div>
      )}

      <hr class="cta-divider" />
      <div class="cta-row">
        <a
          class="cta-primary"
          href={job.url}
          target="_blank"
          rel="noopener noreferrer"
        >
          Apply →
        </a>
        <a
          class="cta-secondary"
          href={boredCvLink(job.url)}
          target="_blank"
          rel="noopener noreferrer"
        >
          ✨ Tailor my CV first
        </a>
        <button
          type="button"
          class="cta-save"
          data-job-id={job.id}
          data-job-title={job.title}
          data-job-company={companyName}
          data-job-url={`${base}jobs/${jobUrlPath(job)}/`}
          aria-label="Save this job"
        >
          ☆ Save
        </button>
      </div>

      <p class="meta source-note">
        Last seen {formatDate(job.posted_at) || "—"}
        {" · "}
        <a href="mailto:kevin.duchier@gmail.com">request removal</a>.
      </p>
    </article>
  </main>

  <style>
    .job-back {
      max-width: 640px;
      margin: 0 auto 8px;
      font: 500 11px/1 var(--mono);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .job-back a {
      color: var(--muted);
      text-decoration: none;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 2px;
    }
    .job-back a:hover { color: var(--ink); border-bottom-color: var(--ink); }
  </style>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
  />
  <script>
    // Preserve search state on back-nav: if the user came from /search/,
    // "← All jobs" returns to that exact filter set instead of the home page.
    const back = document.getElementById("back-link");
    if (back) {
      const ref = document.referrer;
      if (ref && new URL(ref, location.href).pathname.endsWith("/search/")) {
        back.textContent = "← Back to results";
        back.addEventListener("click", (e) => {
          e.preventDefault();
          history.back();
        });
      }
    }

    // Saved jobs — localStorage-only, no account, no sync. Click the
    // ☆ Save button to bookmark; visit /saved/ to see your list.
    (function () {
      const KEY = "eu-tech-jobs:saved";
      function load() {
        try { return JSON.parse(localStorage.getItem(KEY) || "[]"); }
        catch { return []; }
      }
      function persist(list) {
        localStorage.setItem(KEY, JSON.stringify(list));
      }
      const btn = document.querySelector(".cta-save");
      if (!btn) return;
      const id = btn.dataset.jobId;
      const list = load();
      function isSaved() { return list.some((j) => j.id === id); }
      function refresh() {
        if (isSaved()) {
          btn.textContent = "★ Saved";
          btn.classList.add("is-saved");
        } else {
          btn.textContent = "☆ Save";
          btn.classList.remove("is-saved");
        }
      }
      btn.addEventListener("click", () => {
        if (isSaved()) {
          const idx = list.findIndex((j) => j.id === id);
          list.splice(idx, 1);
        } else {
          list.unshift({
            id,
            title: btn.dataset.jobTitle,
            company: btn.dataset.jobCompany,
            url: btn.dataset.jobUrl,
            saved_at: new Date().toISOString(),
          });
          // Cap at 200 saved jobs.
          list.splice(200);
        }
        persist(list);
        refresh();
      });
      refresh();
    })();
  </script>
</Base>
