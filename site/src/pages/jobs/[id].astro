---
import Base from "../../layouts/Base.astro";
import { jobs, companies, formatDate, displayCountry, boredCvLink } from "../../lib/data";

export async function getStaticPaths() {
  return jobs.map((j) => ({ params: { id: j.id } }));
}

const { id } = Astro.params;
const job = jobs.find((j) => j.id === id);
if (!job) throw new Error(`Job ${id} not found`);
const company = companies[job.company_slug];
const companyName = company?.name || job.company_slug;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---
<Base title={`${job.title} — ${companyName}`} description={`${job.title} at ${companyName} (${job.location || "remote"})`}>
  <header>
    <p class="lede"><a href={base}>← Back</a></p>
  </header>
  <main>
    <article class="job" data-pagefind-body>
      <h1>{job.title}</h1>
      <p class="meta">
        <a href={`${base}companies/${job.company_slug}/`}>{companyName}</a>
        {company?.country && <> · {displayCountry(company.country)}</>}
        {job.location && <> · {job.location}</>}
        {job.posted_at && <> · posted {formatDate(job.posted_at)}</>}
        {" · "}<span class="badge">{job.source}</span>
      </p>
      <div style="display:flex; gap:12px; flex-wrap:wrap; margin: 20px 0;">
        <a
          class="btn-primary"
          href={boredCvLink(job.url)}
          target="_blank"
          rel="noopener noreferrer"
          style="background:var(--accent); color:#fff; padding:10px 16px; border-radius:6px; text-decoration:none; font-weight:500;"
        >
          ✨ Tailor my CV for this job →
        </a>
        <a
          class="btn-secondary"
          href={job.url}
          target="_blank"
          rel="noopener noreferrer"
          style="border:1px solid var(--border); padding:10px 16px; border-radius:6px; text-decoration:none;"
        >
          Apply on {job.source} →
        </a>
      </div>
      <p class="meta" style="margin-top: 16px;">
        Full job description lives on the source ATS — that page is always
        authoritative. We surface listings here but never mirror copy.
      </p>
    </article>
  </main>
  <footer>
    <p>
      Built with <a href="https://aramente.github.io/bored-cv/">Bored CV</a> ·
      Browse <a href={base}>all open jobs</a> ·
      <a href="https://github.com/Aramente/eu-tech-jobs">repo</a>.
    </p>
  </footer>
</Base>
