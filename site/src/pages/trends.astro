---
import Base from "../layouts/Base.astro";
import { jobs, companies, meta, formatDate, countryName } from "../lib/data";

// Aggregations
const jobsByCompany: Record<string, number> = {};
for (const j of jobs) {
  jobsByCompany[j.company_slug] = (jobsByCompany[j.company_slug] || 0) + 1;
}

const totalJobs = jobs.length;
const totalCompanies = Object.keys(companies).length;

// Most hiring (any source)
const topHiringAll = Object.entries(jobsByCompany)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 30)
  .map(([slug, count]) => ({
    slug,
    count,
    name: companies[slug]?.name || slug,
    country: companies[slug]?.country || "",
    isAggregator: slug.startsWith("via-"),
  }));

// Most hiring among curated (drop aggregator-discovered noise)
const topHiringCurated = topHiringAll.filter((c) => !c.isAggregator).slice(0, 25);

// New jobs in the last 7 days
const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
const recentJobs = jobs.filter((j) => j.posted_at && j.posted_at > sevenDaysAgo);
const recentByCompany: Record<string, number> = {};
for (const j of recentJobs) {
  recentByCompany[j.company_slug] = (recentByCompany[j.company_slug] || 0) + 1;
}
const recentlyActive = Object.entries(recentByCompany)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15)
  .map(([slug, count]) => ({
    slug,
    count,
    name: companies[slug]?.name || slug,
    country: companies[slug]?.country || "",
  }));

// Country distribution (curated only)
const byCountry: Record<string, number> = {};
for (const c of Object.values(companies)) {
  if (c.slug?.startsWith("via-")) continue;
  if (c.country) byCountry[c.country] = (byCountry[c.country] || 0) + 1;
}
const countryRows = Object.entries(byCountry)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// Source distribution (ATS vs aggregator split)
const bySource: Record<string, number> = {};
for (const j of jobs) bySource[j.source] = (bySource[j.source] || 0) + 1;
const ATS_SOURCES = new Set(["greenhouse", "lever", "ashby", "workable", "recruitee", "personio", "smartrecruiters"]);
const atsJobs = Object.entries(bySource).filter(([s]) => ATS_SOURCES.has(s));
const aggregatorJobs = Object.entries(bySource).filter(([s]) => !ATS_SOURCES.has(s));

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function bar(value: number, max: number, width = 200): number {
  return Math.max(2, Math.round((value / Math.max(max, 1)) * width));
}
const maxCountry = countryRows[0]?.[1] ?? 1;
const maxHiring = topHiringCurated[0]?.count ?? 1;
const maxRecent = recentlyActive[0]?.count ?? 1;
---
<Base title="Methodology — eu-tech-jobs">
  <main>
    <p class="page-marker">Methodology · refreshed {formatDate(meta.run_at)}</p>

    <section class="trends-section">
      <h2 class="trends-h">Top hiring companies</h2>
      <p class="trends-sub">Highest open-job counts among the {Object.values(companies).filter((c) => !c.slug?.startsWith("via-")).length} hand-curated EU companies.</p>
      <table>
        <thead><tr><th>Rank</th><th>Company</th><th>Country</th><th class="num">Jobs</th><th></th></tr></thead>
        <tbody>
          {topHiringCurated.map((row, i) => (
            <tr>
              <td class="rank">{String(i + 1).padStart(2, "0")}</td>
              <td><a href={`${base}companies/${row.slug}/`}>{row.name}</a></td>
              <td class="meta">{countryName(row.country)}</td>
              <td class="num"><strong>{row.count}</strong></td>
              <td class="bar-cell">
                <span class="bar" style={`width:${bar(row.count, maxHiring)}px`}></span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    {recentlyActive.length > 0 && (
      <section class="trends-section">
        <h2 class="trends-h">Hiring this week</h2>
        <p class="trends-sub">New positions in the last 7 days.</p>
        <table>
          <thead><tr><th>Rank</th><th>Company</th><th>Country</th><th class="num">New (7d)</th><th></th></tr></thead>
          <tbody>
            {recentlyActive.map((row, i) => (
              <tr>
                <td class="rank">{String(i + 1).padStart(2, "0")}</td>
                <td><a href={`${base}companies/${row.slug}/`}>{row.name}</a></td>
                <td class="meta">{countryName(row.country)}</td>
                <td class="num"><strong>{row.count}</strong></td>
                <td class="bar-cell">
                  <span class="bar" style={`width:${bar(row.count, maxRecent)}px`}></span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    <section class="trends-section">
      <h2 class="trends-h">Coverage by country</h2>
      <p class="trends-sub">Top 15 countries by curated-company count.</p>
      <table>
        <thead><tr><th>Country</th><th class="num">Companies</th><th></th></tr></thead>
        <tbody>
          {countryRows.map(([cc, n]) => (
            <tr>
              <td>{countryName(cc)}</td>
              <td class="num"><strong>{n}</strong></td>
              <td class="bar-cell">
                <span class="bar" style={`width:${bar(n, maxCountry)}px`}></span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="trends-section">
      <h2 class="trends-h">How we collect this</h2>
      <p class="trends-sub max-prose">
        We pull jobs daily from <strong>{atsJobs.length} ATS APIs</strong> (Greenhouse, Lever, Ashby, Workable, Recruitee, Personio, SmartRecruiters)
        and <strong>{aggregatorJobs.length} EU job aggregators</strong>. No LinkedIn or Indeed scraping. Companies are PR-curated. Raw parquet snapshots are mirrored to <a href="https://huggingface.co/datasets/Aramente/eu-tech-jobs">Hugging Face</a> under CC-BY-4.0; pipeline source is on <a href="https://github.com/Aramente/eu-tech-jobs">GitHub</a> under MIT.
      </p>
    </section>
  </main>
  <footer>
    <p>
      Time-series (week-over-week velocity, fastest-growing teams) lands as snapshots accumulate.
    </p>
  </footer>
</Base>

<style>
  .page-marker {
    font: 500 11px/1 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 24px;
  }
  .trends-section { margin: 0 0 48px; }
  .trends-h {
    font: 500 22px/1.2 var(--body);
    letter-spacing: -0.01em;
    margin: 0 0 4px;
    color: var(--ink);
  }
  .trends-sub {
    font: 400 13px/1.55 var(--body);
    color: var(--muted);
    margin: 0 0 16px;
    max-width: 70ch;
  }
  .max-prose { max-width: 70ch; font-size: 14px; line-height: 1.6; }
  td.rank, td.num { font-family: var(--mono); font-variant-numeric: tabular-nums; }
  td.rank { color: var(--muted); width: 36px; }
  td.num { width: 80px; }
  td.num strong { color: var(--ink); font-weight: 600; }
  td.bar-cell { width: 220px; }
  .bar {
    display: inline-block;
    height: 4px;
    background: var(--ink);
  }
</style>
