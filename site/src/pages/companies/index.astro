---
import Base from "../../layouts/Base.astro";
import { companies, jobsByCompany, displayCountry } from "../../lib/data";

const byCompany = jobsByCompany();
const list = Object.values(companies).sort((a, b) => a.name.localeCompare(b.name));
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---
<Base title="Companies — eu-tech-jobs">
  <header>
    <h1>Companies ({list.length})</h1>
    <p class="lede">
      <a href={base}>← Back</a> · All curated companies. PR a new one at
      <a href="https://github.com/Aramente/eu-tech-jobs/blob/main/CONTRIBUTING.md">CONTRIBUTING.md</a>.
    </p>
  </header>
  <main>
    <div class="company-grid">
      {list.map((c) => (
        <a class="company-card" href={`${base}companies/${c.slug}/`}>
          <h3>{c.name} <span class="badge">{displayCountry(c.country)}</span></h3>
          <p class="meta">
            {byCompany[c.slug]?.length ?? 0} open · {c.categories?.join(", ") || "—"}
          </p>
        </a>
      ))}
    </div>
  </main>
</Base>
