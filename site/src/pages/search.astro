---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
---
<Base title="Search jobs — eu-tech-jobs" description="Filter 12,000+ EU AI/tech jobs by location, role, seniority, and remote policy.">
  <header>
    <h1>Search jobs</h1>
    <p class="lede">
      <a href={base}>← Back</a> · Full-text search with filters: location,
      role family, seniority, remote policy. Combine multiple filters across
      different categories with <strong>AND</strong>, multi-select within
      a category with <strong>OR</strong>.
    </p>
    <p class="meta">
      Tip — pick "France" + "Remote — Europe" + "Remote — Worldwide"
      under <em>where</em> for "France <strong>or</strong> remote-friendly".
      Layer on a role to AND-narrow.
    </p>
  </header>
  <main>
    <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
    <div id="search"></div>
    <script is:inline src={`${base}pagefind/pagefind-ui.js`}></script>
    <script is:inline define:vars={{ base }}>
      // Pagefind UI doesn't auto-read filter URL params (only ?q=).
      // We parse them ourselves and click the matching checkboxes after
      // the filter panel renders. Supports `?filter[where]=France` from
      // the home-page dropdowns and bookmarkable filter combinations.
      function parseFilterParams() {
        const out = {};
        const usp = new URLSearchParams(location.search);
        for (const [key, value] of usp.entries()) {
          const m = key.match(/^filter\[([^\]]+)\](?:\[\])?$/);
          if (m) {
            (out[m[1]] = out[m[1]] || []).push(value);
          }
        }
        return out;
      }

      function applyUrlFilters(filters) {
        // Wait for the filter panel to render — Pagefind builds it
        // asynchronously after the first search runs (or after the empty
        // search runs).
        let attempts = 0;
        const tryApply = () => {
          attempts++;
          let allFound = true;
          for (const [key, values] of Object.entries(filters)) {
            for (const v of values) {
              const block = document.querySelector(
                `.pagefind-ui__filter-block[data-filter-name="${key}"]`,
              );
              if (!block) { allFound = false; continue; }
              // Pagefind renders each option as a label with the text
              // matching the value. Find the matching checkbox.
              const labels = block.querySelectorAll(
                ".pagefind-ui__filter-value",
              );
              let hit = null;
              for (const lbl of labels) {
                const txt = (lbl.textContent || "")
                  .replace(/\s*\(\d[\d,]*\)\s*$/, "")
                  .trim();
                if (txt === v) { hit = lbl; break; }
              }
              if (!hit) { allFound = false; continue; }
              const cb = hit.querySelector('input[type="checkbox"]');
              if (cb && !cb.checked) { cb.click(); }
            }
          }
          if (!allFound && attempts < 20) {
            setTimeout(tryApply, 250);
          }
        };
        setTimeout(tryApply, 300);
      }

      function mountSearch() {
        if (typeof PagefindUI === "undefined") {
          setTimeout(mountSearch, 100);
          return;
        }
        const ui = new PagefindUI({
          element: "#search",
          showSubResults: false,
          showImages: false,
          baseUrl: base,
          showEmptyFilters: true,
          translations: {
            placeholder: "search 12,000+ EU AI/tech jobs",
            filters_label: "Refine results",
          },
        });

        const filters = parseFilterParams();
        const usp = new URLSearchParams(location.search);
        const q = usp.get("q") || "";

        if (Object.keys(filters).length > 0 || q) {
          // Trigger an empty search (or initial query) so Pagefind
          // renders the filter panel — we then tick the right boxes.
          // Pagefind UI requires *some* trigger before filters appear.
          if (q) {
            // Already handled by Pagefind UI's built-in ?q= reader.
          } else {
            // Simulate typing a single space to force initial render of
            // results + filter panel, then immediately clear it.
            const input = document.querySelector(
              ".pagefind-ui__search-input",
            );
            if (input) {
              input.focus();
              // Use the synthetic event Pagefind listens to.
              input.value = "";
              input.dispatchEvent(new Event("input", { bubbles: true }));
            }
            // Pagefind also shows "All N results" on empty search if
            // showEmptyFilters is true. The filter panel renders even
            // without a query in 1.5+.
          }
          applyUrlFilters(filters);
        }
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", mountSearch);
      } else {
        mountSearch();
      }
    </script>
  </main>
</Base>

<style>
  /* Pagefind UI customization to match site theme */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--row-hover);
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: inherit;
    margin-top: 16px;
  }
  :global(.pagefind-ui__search-input) {
    font-size: 16px !important;
  }
  :global(.pagefind-ui__filter-panel) {
    margin-top: 12px;
  }
  :global(.pagefind-ui__filter-block details) {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    margin-bottom: 8px;
  }
  :global(.pagefind-ui__filter-block summary) {
    font-weight: 500;
    cursor: pointer;
    padding: 4px 0;
  }
</style>
