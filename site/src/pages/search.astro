---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
---
<Base title="Search — eu-tech-jobs" description="Filter EU AI/tech jobs by location, role, seniority, and remote policy.">
  <header class="search-header">
    <p class="crumb"><a href={base}>← All jobs</a></p>
  </header>
  <main class="search-page">
    <div class="search-shell">
      <aside class="filter-rail">
        <div class="filter-search">
          <input id="q" type="search" placeholder="Search…" autocomplete="off" />
        </div>
        <div id="filter-panels"></div>
        <button id="reset" type="button" class="rail-clear">Clear all</button>
      </aside>
      <section class="results">
        <div id="active-pills" class="active-pills" hidden></div>
        <p id="result-summary" class="result-summary">Loading…</p>
        <ol id="result-list" class="results-list"></ol>
        <nav id="pager" class="pagination"></nav>
      </section>
    </div>

    <script is:inline define:vars={{ base }}>
      const PAGE_SIZE = 25;

      const elQ = document.getElementById("q");
      const elPanels = document.getElementById("filter-panels");
      const elList = document.getElementById("result-list");
      const elSummary = document.getElementById("result-summary");
      const elPager = document.getElementById("pager");
      const elReset = document.getElementById("reset");
      const elPills = document.getElementById("active-pills");

      const FACET_LABELS = {
        where: "Where",
        role: "Role",
        seniority: "Seniority",
        remote: "Remote",
        company: "Company",
      };

      const selected = {};
      let currentPage = 1;

      function syncFromUrl() {
        const usp = new URLSearchParams(location.search);
        const q = usp.get("q") || "";
        if (q) elQ.value = q;
        for (const [k, v] of usp.entries()) {
          const m = k.match(/^filter\[([^\]]+)\](?:\[\])?$/);
          if (m) {
            const facet = m[1];
            (selected[facet] = selected[facet] || new Set()).add(v);
          }
        }
      }

      function syncToUrl() {
        const usp = new URLSearchParams();
        const q = elQ.value.trim();
        if (q) usp.set("q", q);
        for (const [facet, values] of Object.entries(selected)) {
          for (const v of values) usp.append(`filter[${facet}][]`, v);
        }
        const url = `${location.pathname}${usp.toString() ? "?" + usp.toString() : ""}`;
        history.replaceState(null, "", url);
      }

      let pagefind = null;
      let allFilters = null;

      async function initPagefind() {
        try {
          pagefind = await import(/* @vite-ignore */ `${base}pagefind/pagefind.js`);
          await pagefind.options({ baseUrl: base });
          allFilters = await pagefind.filters();
          renderFilterPanels();
          syncFromUrl();
          for (const [facet, values] of Object.entries(selected)) {
            for (const v of values) {
              const cb = document.querySelector(
                `input[type="checkbox"][data-facet="${facet}"][value="${CSS.escape(v)}"]`,
              );
              if (cb) cb.checked = true;
            }
          }
          await runSearch();
        } catch (err) {
          elSummary.textContent = "Search index failed to load: " + (err.message || err);
        }
      }

      function renderFilterPanels() {
        if (!allFilters) return;
        const order = ["where", "role", "seniority", "remote", "company"];
        elPanels.innerHTML = "";
        for (const facet of order) {
          const values = allFilters[facet];
          if (!values || Object.keys(values).length === 0) continue;
          const sortedValues = Object.entries(values).sort((a, b) => b[1] - a[1]);
          const cap = facet === "company" ? 30 : sortedValues.length;
          const visible = sortedValues.slice(0, cap);
          const hidden = sortedValues.slice(cap);
          const block = document.createElement("details");
          block.className = "filter-block";
          block.open = facet === "where" || facet === "role";
          const summary = document.createElement("summary");
          summary.innerHTML = `<span class="filter-block-label">${FACET_LABELS[facet] || facet}</span><span class="filter-block-toggle" aria-hidden="true">+</span>`;
          block.appendChild(summary);
          const wrap = document.createElement("div");
          wrap.className = "filter-options";
          const renderOpt = ([val, count]) => {
            const id = `f-${facet}-${val.replace(/[^a-zA-Z0-9_-]/g, "_")}`;
            const label = document.createElement("label");
            label.className = "filter-option";
            const input = document.createElement("input");
            input.type = "checkbox";
            input.id = id;
            input.value = val;
            input.dataset.facet = facet;
            input.addEventListener("change", () => {
              if (!selected[facet]) selected[facet] = new Set();
              if (input.checked) selected[facet].add(val);
              else selected[facet].delete(val);
              if (selected[facet].size === 0) delete selected[facet];
              currentPage = 1;
              syncToUrl();
              runSearch();
            });
            const text = document.createElement("span");
            text.className = "filter-option-text";
            text.innerHTML = `<span class="opt-name">${val}</span><span class="opt-count">${count.toLocaleString()}</span>`;
            label.appendChild(input);
            label.appendChild(text);
            return label;
          };
          for (const v of visible) wrap.appendChild(renderOpt(v));
          if (hidden.length > 0) {
            const more = document.createElement("button");
            more.type = "button";
            more.className = "more-link";
            more.textContent = `+ ${hidden.length} more`;
            more.addEventListener("click", () => {
              for (const v of hidden) wrap.insertBefore(renderOpt(v), more);
              more.remove();
            });
            wrap.appendChild(more);
          }
          block.appendChild(wrap);
          elPanels.appendChild(block);
        }
      }

      function renderActivePills() {
        if (!elPills) return;
        const entries = [];
        for (const [facet, set] of Object.entries(selected)) {
          for (const v of set) entries.push([facet, v]);
        }
        if (entries.length === 0) {
          elPills.hidden = true;
          elPills.innerHTML = "";
          return;
        }
        elPills.hidden = false;
        elPills.innerHTML = "";
        for (const [facet, v] of entries) {
          const pill = document.createElement("button");
          pill.type = "button";
          pill.className = "active-pill";
          pill.innerHTML = `<span class="pill-facet">${FACET_LABELS[facet] || facet}</span><span class="pill-value">${v}</span><span class="pill-x" aria-hidden="true">×</span>`;
          pill.setAttribute("aria-label", `Remove filter ${facet}: ${v}`);
          pill.addEventListener("click", () => {
            selected[facet]?.delete(v);
            if (selected[facet] && selected[facet].size === 0) delete selected[facet];
            const cb = document.querySelector(
              `input[type="checkbox"][data-facet="${facet}"][value="${CSS.escape(v)}"]`,
            );
            if (cb) cb.checked = false;
            currentPage = 1;
            syncToUrl();
            runSearch();
          });
          elPills.appendChild(pill);
        }
      }

      async function runSearch() {
        if (!pagefind) return;
        const q = elQ.value.trim();
        renderActivePills();
        const filters = {};
        for (const [facet, set] of Object.entries(selected)) {
          if (set.size === 0) continue;
          const arr = Array.from(set);
          filters[facet] = arr.length === 1 ? arr[0] : { any: arr };
        }
        elSummary.textContent = "Searching…";
        const result = q
          ? await pagefind.search(q, { filters })
          : await pagefind.search(null, { filters });
        if (!result) {
          elSummary.textContent = "Index unavailable.";
          elList.innerHTML = "";
          elPager.innerHTML = "";
          return;
        }
        const total = result.results.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = 1;
        const start = (currentPage - 1) * PAGE_SIZE;
        const slice = result.results.slice(start, start + PAGE_SIZE);
        if (total === 0) {
          elSummary.innerHTML = `<span class="empty-line">No matches.</span> <button type="button" class="empty-clear" id="empty-clear">Clear filters</button>`;
          const ec = document.getElementById("empty-clear");
          ec?.addEventListener("click", () => elReset.click());
        } else {
          elSummary.innerHTML = `<strong>${total.toLocaleString()}</strong> <span class="muted">jobs · ${start + 1}–${Math.min(start + PAGE_SIZE, total)}</span>`;
        }
        elList.innerHTML = "";
        const datas = await Promise.all(slice.map((r) => r.data()));
        for (const d of datas) {
          const li = document.createElement("li");
          li.className = "result-item";
          const m = d.meta || {};
          let posted = "";
          if (m.posted) {
            const days = Math.round((Date.now() - new Date(m.posted).getTime()) / 86400000);
            posted = days <= 1 ? "today" : days <= 7 ? `${days}d ago` : days <= 31 ? `${Math.round(days / 7)}w ago` : "";
          }
          const where = m.where && m.where !== "Other" ? m.where : (m.country || m.location || "");
          const remoteBadge = m.remote && m.remote.startsWith("remote") ? "Remote" : "";
          const metaBits = [m.company, where, posted, remoteBadge].filter(Boolean).join(" · ");
          const a = document.createElement("a");
          a.href = d.url;
          a.className = "result-link";
          // One-liner: title (truncates) on the left, meta (mono) right-aligned.
          a.innerHTML = `
            <span class="result-title">${m.title || d.url}</span>
            <span class="result-meta">${metaBits}</span>
          `;
          li.appendChild(a);
          elList.appendChild(li);
        }
        renderPager(totalPages);
      }

      function renderPager(totalPages) {
        elPager.innerHTML = "";
        if (totalPages <= 1) return;
        const mk = (p, label, active) => {
          const el = document.createElement(active ? "span" : "a");
          el.textContent = label || String(p);
          if (active) el.className = "current";
          else {
            el.href = "#";
            el.addEventListener("click", (e) => {
              e.preventDefault();
              currentPage = p;
              runSearch();
              window.scrollTo(0, 0);
            });
          }
          elPager.appendChild(el);
        };
        if (currentPage > 1) mk(currentPage - 1, "← Prev");
        const max = Math.min(totalPages, 8);
        for (let p = 1; p <= max; p++) mk(p, String(p), p === currentPage);
        if (totalPages > max) {
          const dots = document.createElement("span");
          dots.textContent = "…";
          elPager.appendChild(dots);
          mk(totalPages, String(totalPages), totalPages === currentPage);
        }
        if (currentPage < totalPages) mk(currentPage + 1, "Next →");
      }

      let textTimer = null;
      elQ.addEventListener("input", () => {
        clearTimeout(textTimer);
        textTimer = setTimeout(() => {
          currentPage = 1;
          syncToUrl();
          runSearch();
        }, 200);
      });

      elReset.addEventListener("click", () => {
        for (const facet of Object.keys(selected)) delete selected[facet];
        elQ.value = "";
        for (const cb of document.querySelectorAll("#filter-panels input[type=checkbox]")) {
          cb.checked = false;
        }
        currentPage = 1;
        syncToUrl();
        runSearch();
      });

      initPagefind();
    </script>
  </main>
</Base>

<style>
  /* Header — slim breadcrumb only */
  .search-header { padding: 24px 24px 0; max-width: 1200px; margin: 0 auto; }
  .crumb { margin: 0; font-size: 13px; color: var(--muted); }
  .crumb a { color: var(--muted); text-decoration: none; border-bottom: 1px solid var(--border); padding-bottom: 1px; }
  .crumb a:hover { color: var(--fg); border-color: var(--accent); }

  .search-page { padding-top: 32px; }

  .search-shell {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 56px;
    margin-top: 8px;
  }
  @media (max-width: 800px) {
    .search-shell { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Filter rail */
  .filter-rail { padding-right: 0; }
  .filter-search input {
    width: 100%;
    padding: 8px 0;
    font-size: 14px;
    border: 0;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    color: var(--fg);
    margin-bottom: 24px;
    outline: none;
  }
  .filter-search input:focus { border-bottom-color: var(--ink); }
  .filter-search input::placeholder { color: var(--muted); }

  details.filter-block {
    border: 0;
    padding: 0;
    margin-bottom: 24px;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }
  details.filter-block:first-of-type { border-top: 0; padding-top: 0; }
  details.filter-block summary {
    cursor: pointer;
    padding: 0 0 6px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  details.filter-block summary::-webkit-details-marker { display: none; }
  .filter-block-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .filter-block-toggle {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    width: 12px;
    text-align: right;
  }
  details[open] .filter-block-toggle::before { content: "−"; }
  details:not([open]) .filter-block-toggle::before { content: "+"; }
  .filter-block-toggle { /* glyph rendered via ::before */ }
  details[open] > summary .filter-block-toggle,
  details:not([open]) > summary .filter-block-toggle { /* hide raw text */ font-size: 0; }
  details[open] > summary .filter-block-toggle::before,
  details:not([open]) > summary .filter-block-toggle::before { font-size: 13px; }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 6px 0 0;
    max-height: 280px;
    overflow-y: auto;
  }
  .filter-option {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    cursor: pointer;
    padding: 4px 0;
    line-height: 1.4;
  }
  .filter-option-text {
    display: flex;
    justify-content: space-between;
    flex: 1;
    gap: 8px;
    min-width: 0;
  }
  .filter-option:hover .opt-name { color: var(--fg); }
  .filter-option input[type=checkbox] {
    margin: 0;
    accent-color: var(--ink);
    flex-shrink: 0;
  }
  .filter-option .opt-name {
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .filter-option .opt-count {
    color: var(--muted);
    font-size: 12px;
    font-variant-numeric: tabular-nums;
  }
  .more-link {
    background: none;
    border: 0;
    padding: 6px 0 0;
    color: var(--muted);
    font-size: 12px;
    cursor: pointer;
    text-align: left;
  }
  .more-link:hover { color: var(--fg); }

  .rail-clear {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 12px 0 0;
    color: var(--muted);
    font: inherit;
    font-size: 12px;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
  }
  .rail-clear:hover { color: var(--fg); text-decoration-color: var(--accent); }

  /* Results column — full width to host one-liner rows with right-aligned meta */
  .results { max-width: 100%; }
  .result-summary {
    color: var(--muted);
    font-size: 12px;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 16px;
  }
  .result-summary strong {
    color: var(--fg);
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
    margin-right: 6px;
  }
  .result-summary .muted { color: var(--muted); }
  .empty-line { color: var(--fg); font-family: var(--serif); font-size: 15px; text-transform: none; letter-spacing: 0; }
  .empty-clear {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin-left: 8px;
    color: var(--muted);
    font: inherit;
    font-family: var(--serif);
    font-size: 14px;
    text-transform: none;
    letter-spacing: 0;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .empty-clear:hover { color: var(--fg); }

  .results-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .result-item {
    border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
    padding: 0;
  }
  .result-item:last-child { border-bottom: 0; }
  .result-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    text-decoration: none;
    color: var(--fg);
    padding: 12px 0 12px 0;
    transition: padding 120ms ease, box-shadow 120ms ease;
  }
  .result-link:hover {
    box-shadow: inset 3px 0 0 var(--accent);
    padding-left: 14px;
  }
  .result-title {
    font-weight: 500;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: -0.005em;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .result-link:hover .result-title { color: var(--fg); }
  .result-meta {
    color: var(--muted);
    font-size: 11px;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex: 0 0 auto;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 50%;
  }
  #pager { justify-content: center; margin-top: 32px; }

  /* Active pills */
  .active-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 16px;
  }
  .active-pill {
    appearance: none;
    background: var(--row-hover);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 10px 4px 12px;
    font: inherit;
    font-size: 12px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background 80ms ease, border-color 80ms ease;
  }
  .active-pill:hover { background: var(--ink); color: var(--on-ink); border-color: var(--ink); }
  .active-pill .pill-facet {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .active-pill:hover .pill-facet { color: var(--on-ink); opacity: 0.7; }
  .active-pill .pill-value { font-weight: 500; }
  .active-pill .pill-x { font-size: 14px; opacity: 0.7; margin-left: 2px; }

  @media (max-width: 700px) {
    /* On narrow screens, fall back to stacked title + meta to avoid
       truncating the title against a meta string. */
    .result-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 14px 0;
    }
    .result-title { white-space: normal; overflow: visible; text-overflow: clip; font-size: 15px; }
    .result-meta { text-align: left; max-width: 100%; font-size: 10px; }
  }
</style>
