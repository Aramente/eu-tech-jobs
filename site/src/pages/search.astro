---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
---
<Base title="Search — eu-tech-jobs" description="Filter EU AI/tech jobs by location, role, seniority, and remote policy.">
  <main class="search-page">
    <div class="search-shell">
      <aside class="filter-rail">
        <div class="filter-search search-input-wrap">
          <input id="q" type="search" class="search-input" placeholder="search…" autocomplete="off" />
        </div>
        <div id="filter-panels">
          {[
            ["where", "Where"],
            ["role", "Role"],
            ["type", "Type"],
            ["remote", "Remote"],
          ].map(([id, label]) => (
            <details class="filter-block" data-facet={id} open={id === "where" || id === "role"}>
              <summary>
                <span class="filter-block-label">{label}</span>
              </summary>
              <div class="filter-options"><p class="rail-loading">loading…</p></div>
            </details>
          ))}
        </div>
        <button id="reset" type="button" class="rail-clear">Clear all</button>
      </aside>
      <section class="results">
        <div id="active-pills" class="active-pills" hidden></div>
        <p id="result-summary" class="result-summary">Loading…</p>
        <ol id="result-list" class="results-list"></ol>
        <nav id="pager" class="pagination"></nav>
      </section>
    </div>

    <script is:inline define:vars={{ base }}>
      const PAGE_SIZE = 25;

      const elQ = document.getElementById("q");
      const elPanels = document.getElementById("filter-panels");
      const elList = document.getElementById("result-list");
      const elSummary = document.getElementById("result-summary");
      const elPager = document.getElementById("pager");
      const elReset = document.getElementById("reset");
      const elPills = document.getElementById("active-pills");

      const FACET_LABELS = {
        where: "Where",
        role: "Role",
        type: "Type",
        remote: "Remote",
      };

      const selected = {};
      let currentPage = 1;

      function syncFromUrl() {
        const usp = new URLSearchParams(location.search);
        const q = usp.get("q") || "";
        if (q) elQ.value = q;
        for (const [k, v] of usp.entries()) {
          const m = k.match(/^filter\[([^\]]+)\](?:\[\])?$/);
          if (m) {
            const facet = m[1];
            (selected[facet] = selected[facet] || new Set()).add(v);
          }
        }
      }

      function syncToUrl() {
        const usp = new URLSearchParams();
        const q = elQ.value.trim();
        if (q) usp.set("q", q);
        for (const [facet, values] of Object.entries(selected)) {
          for (const v of values) usp.append(`filter[${facet}][]`, v);
        }
        const url = `${location.pathname}${usp.toString() ? "?" + usp.toString() : ""}`;
        history.replaceState(null, "", url);
      }

      let pagefind = null;
      let allFilters = null;

      async function initPagefind() {
        try {
          pagefind = await import(/* @vite-ignore */ `${base}pagefind/pagefind.js`);
          await pagefind.options({ baseUrl: base });
          allFilters = await pagefind.filters();
          renderFilterPanels();
          syncFromUrl();
          for (const [facet, values] of Object.entries(selected)) {
            for (const v of values) {
              const cb = document.querySelector(
                `input[type="checkbox"][data-facet="${facet}"][value="${CSS.escape(v)}"]`,
              );
              if (cb) cb.checked = true;
            }
          }
          await runSearch();
        } catch (err) {
          elSummary.textContent = "Search index failed to load: " + (err.message || err);
        }
      }

      function renderFilterPanels() {
        if (!allFilters) return;
        // Populate the pre-rendered <details> blocks (SSR placeholder) instead
        // of wiping innerHTML — keeps first-paint stable, no flicker.
        for (const block of elPanels.querySelectorAll("details.filter-block")) {
          const facet = block.dataset.facet;
          const wrap = block.querySelector(".filter-options");
          const values = allFilters[facet];
          if (!values || Object.keys(values).length === 0) {
            block.style.display = "none";
            continue;
          }
          const sortedValues = facet === "where"
            ? Object.entries(values).sort((a, b) => {
                const rank = (k) => k === "Remote" ? 0 : k === "France" ? 1 : 2;
                const ra = rank(a[0]);
                const rb = rank(b[0]);
                if (ra !== rb) return ra - rb;
                return a[0].localeCompare(b[0]);
              })
            : Object.entries(values).sort((a, b) => b[1] - a[1]);
          const cap = facet === "company" ? 30 : sortedValues.length;
          const visible = sortedValues.slice(0, cap);
          const hidden = sortedValues.slice(cap);
          wrap.innerHTML = "";
          const renderOpt = ([val, count]) => {
            const id = `f-${facet}-${val.replace(/[^a-zA-Z0-9_-]/g, "_")}`;
            const label = document.createElement("label");
            label.className = "filter-option";
            const input = document.createElement("input");
            input.type = "checkbox";
            input.id = id;
            input.value = val;
            input.dataset.facet = facet;
            input.addEventListener("change", () => {
              if (!selected[facet]) selected[facet] = new Set();
              if (input.checked) selected[facet].add(val);
              else selected[facet].delete(val);
              if (selected[facet].size === 0) delete selected[facet];
              currentPage = 1;
              syncToUrl();
              runSearch();
            });
            // Filter labels are clean — no count next to each option per UX call.
            // The pretty value: type values come through as "permanent" etc; capitalize.
            const display = facet === "type"
              ? val.charAt(0).toUpperCase() + val.slice(1)
              : val;
            const text = document.createElement("span");
            text.className = "filter-option-text";
            text.innerHTML = `<span class="opt-name">${display}</span>`;
            label.appendChild(input);
            label.appendChild(text);
            return label;
          };
          for (const v of visible) wrap.appendChild(renderOpt(v));
          if (hidden.length > 0) {
            const more = document.createElement("button");
            more.type = "button";
            more.className = "more-link";
            more.textContent = `+ ${hidden.length} more`;
            more.addEventListener("click", () => {
              for (const v of hidden) wrap.insertBefore(renderOpt(v), more);
              more.remove();
            });
            wrap.appendChild(more);
          }
        }
      }

      function renderActivePills() {
        if (!elPills) return;
        const entries = [];
        for (const [facet, set] of Object.entries(selected)) {
          for (const v of set) entries.push([facet, v]);
        }
        if (entries.length === 0) {
          elPills.hidden = true;
          elPills.innerHTML = "";
          return;
        }
        elPills.hidden = false;
        elPills.innerHTML = "";
        for (const [facet, v] of entries) {
          const pill = document.createElement("button");
          pill.type = "button";
          pill.className = "active-pill";
          pill.innerHTML = `<span class="pill-facet">${FACET_LABELS[facet] || facet}</span><span class="pill-value">${v}</span><span class="pill-x" aria-hidden="true">×</span>`;
          pill.setAttribute("aria-label", `Remove filter ${facet}: ${v}`);
          pill.addEventListener("click", () => {
            selected[facet]?.delete(v);
            if (selected[facet] && selected[facet].size === 0) delete selected[facet];
            const cb = document.querySelector(
              `input[type="checkbox"][data-facet="${facet}"][value="${CSS.escape(v)}"]`,
            );
            if (cb) cb.checked = false;
            currentPage = 1;
            syncToUrl();
            runSearch();
          });
          elPills.appendChild(pill);
        }
      }

      async function runSearch() {
        if (!pagefind) return;
        const q = elQ.value.trim();
        renderActivePills();
        const filters = {};
        for (const [facet, set] of Object.entries(selected)) {
          if (set.size === 0) continue;
          const arr = Array.from(set);
          filters[facet] = arr.length === 1 ? arr[0] : { any: arr };
        }
        elSummary.textContent = "Searching…";
        const result = q
          ? await pagefind.search(q, { filters })
          : await pagefind.search(null, { filters });
        if (!result) {
          elSummary.textContent = "Index unavailable.";
          elList.innerHTML = "";
          elPager.innerHTML = "";
          return;
        }
        const total = result.results.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = 1;
        const start = (currentPage - 1) * PAGE_SIZE;
        const slice = result.results.slice(start, start + PAGE_SIZE);
        if (total === 0) {
          elSummary.innerHTML = `<span class="empty-line">No matches.</span> <button type="button" class="empty-clear" id="empty-clear">Clear filters</button>`;
          const ec = document.getElementById("empty-clear");
          ec?.addEventListener("click", () => elReset.click());
        } else {
          elSummary.innerHTML = `<strong>${total.toLocaleString()}</strong> <span class="muted">jobs · ${start + 1}–${Math.min(start + PAGE_SIZE, total)}</span>`;
        }
        elList.innerHTML = "";
        const datas = await Promise.all(slice.map((r) => r.data()));
        const now = Date.now();
        const yearNow = new Date(now).getUTCFullYear();
        for (const d of datas) {
          const li = document.createElement("li");
          li.className = "result-item";
          const m = d.meta || {};
          let isNew = false;
          let postedLabel = "";
          if (m.posted) {
            const t = new Date(m.posted).getTime();
            const yr = new Date(m.posted).getUTCFullYear();
            if (isFinite(t) && t <= now && yr <= yearNow) {
              const days = Math.floor((now - t) / 86400000);
              isNew = days <= 1;
              postedLabel = days <= 0 ? "TODAY" : days === 1 ? "1D" : days <= 7 ? `${days}D` : days <= 31 ? `${Math.round(days / 7)}W` : `${Math.round(days / 30)}MO`;
            }
          }
          const where = m.where && m.where !== "Other" ? m.where : (m.country || m.location || "");
          const remoteLabel =
            m.remote === "remote-global" ? "REMOTE-WW"
            : m.remote === "remote-eu" ? "REMOTE-EU"
            : m.remote === "remote" ? "REMOTE"
            : m.remote === "hybrid" ? "HYBRID"
            : "";
          const metaBits = [
            isNew ? `<span class="new">NEW</span>` : postedLabel,
            remoteLabel,
          ].filter(Boolean).join(" · ");
          const orgBits = [m.company, where].filter(Boolean).join(" · ");
          const a = document.createElement("a");
          a.href = d.url;
          a.className = "result-link";
          a.innerHTML = `
            <span class="result-title">${m.title || d.url}</span>
            <span class="result-org">${orgBits}</span>
            <span class="result-meta">${metaBits}</span>
          `;
          li.appendChild(a);
          elList.appendChild(li);
        }
        renderPager(totalPages);
      }

      function renderPager(totalPages) {
        elPager.innerHTML = "";
        if (totalPages <= 1) return;
        const mk = (p, label, active) => {
          const el = document.createElement(active ? "span" : "a");
          el.textContent = label || String(p);
          if (active) el.className = "current";
          else {
            el.href = "#";
            el.addEventListener("click", (e) => {
              e.preventDefault();
              currentPage = p;
              runSearch();
              window.scrollTo(0, 0);
            });
          }
          elPager.appendChild(el);
        };
        if (currentPage > 1) mk(currentPage - 1, "← Prev");
        const max = Math.min(totalPages, 8);
        for (let p = 1; p <= max; p++) mk(p, String(p), p === currentPage);
        if (totalPages > max) {
          const dots = document.createElement("span");
          dots.textContent = "…";
          elPager.appendChild(dots);
          mk(totalPages, String(totalPages), totalPages === currentPage);
        }
        if (currentPage < totalPages) mk(currentPage + 1, "Next →");
      }

      let textTimer = null;
      elQ.addEventListener("input", () => {
        clearTimeout(textTimer);
        textTimer = setTimeout(() => {
          currentPage = 1;
          syncToUrl();
          runSearch();
        }, 200);
      });

      elReset.addEventListener("click", () => {
        for (const facet of Object.keys(selected)) delete selected[facet];
        elQ.value = "";
        for (const cb of document.querySelectorAll("#filter-panels input[type=checkbox]")) {
          cb.checked = false;
        }
        currentPage = 1;
        syncToUrl();
        runSearch();
      });

      initPagefind();
    </script>
  </main>
</Base>

<style>
  /* Per-DESIGN.md v0.2: search-specific layout. Result row CSS lives in
     global.css (.result-link 3-col grid) — don't redefine here. */
  .search-page { padding-top: 16px; }

  .search-shell {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    margin-top: 8px;
  }
  @media (max-width: 800px) {
    .search-shell { grid-template-columns: 1fr; gap: 24px; }
  }

  .filter-rail { padding-right: 0; }
  .filter-search { margin-bottom: 24px; }

  details.filter-block {
    border: 0;
    padding: 12px 0 0;
    margin-bottom: 16px;
    border-top: 1px solid var(--rule);
  }
  details.filter-block:first-of-type { border-top: 0; padding-top: 0; }
  details.filter-block summary {
    cursor: pointer;
    padding: 0 0 6px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
  }
  details.filter-block summary::-webkit-details-marker { display: none; }
  details.filter-block summary::after {
    content: "+";
    font: 500 13px/1 var(--mono);
    color: var(--muted);
    width: 12px;
    text-align: right;
  }
  details[open].filter-block summary::after { content: "−"; }
  details.filter-block summary:hover::after { color: var(--ink); }
  .filter-block-label {
    font: 500 11px/1 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  details[open].filter-block .filter-block-label,
  details.filter-block summary:hover .filter-block-label { color: var(--ink); }
  .rail-loading {
    font: 400 12px/1.4 var(--mono);
    color: var(--muted);
    margin: 8px 0;
    font-style: italic;
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 6px 0 0;
    max-height: 280px;
    overflow-y: auto;
  }
  .filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    font: 400 13px/1.4 var(--body);
    cursor: pointer;
    padding: 3px 0;
  }
  .filter-option-text {
    display: flex;
    justify-content: space-between;
    flex: 1;
    gap: 8px;
    min-width: 0;
  }
  .filter-option input[type=checkbox] {
    margin: 0;
    accent-color: var(--ink);
    flex-shrink: 0;
  }
  .filter-option .opt-name {
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .filter-option .opt-count {
    color: var(--muted);
    font: 500 11px/1.4 var(--mono);
    font-variant-numeric: tabular-nums;
  }
  .more-link {
    background: none;
    border: 0;
    padding: 6px 0 0;
    color: var(--muted);
    font: 500 11px/1 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    text-align: left;
  }
  .more-link:hover { color: var(--ink); }

  .rail-clear {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 16px 0 0;
    color: var(--muted);
    font: 500 11px/1 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .rail-clear:hover { color: var(--ink); text-decoration-color: var(--ink); }

  .results { max-width: 100%; }
  .result-summary {
    color: var(--muted);
    font: 500 11px/1 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
  }
  .result-summary strong {
    color: var(--ink);
    font-weight: 600;
    margin-right: 4px;
    font-variant-numeric: tabular-nums;
  }
  .empty-line { color: var(--ink); }
  .empty-clear {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin-left: 8px;
    color: var(--muted);
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--ink);
    text-underline-offset: 3px;
  }
  .empty-clear:hover { color: var(--ink); }

  /* Active pills */
  .active-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin: 0 0 12px;
  }
  .active-pill {
    appearance: none;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 3px 8px;
    font: 500 11px/1.4 var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background 80ms ease;
  }
  .active-pill:hover { background: var(--ink); color: var(--paper); }
  .active-pill .pill-facet {
    font-weight: 400;
    color: var(--muted);
  }
  .active-pill:hover .pill-facet { color: var(--paper); opacity: 0.7; }
  .active-pill .pill-value { font-weight: 600; }
  .active-pill .pill-x { font-size: 13px; opacity: 0.8; margin-left: 2px; }

  #pager { justify-content: flex-start; margin-top: 24px; }
</style>
