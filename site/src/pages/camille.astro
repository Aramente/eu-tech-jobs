---
import Base from "../layouts/Base.astro";
import {
  jobsForCamille as jobs,
  companiesForCamille as companies,
  jobUrlPath,
  formatDate,
} from "../lib/data";

// Hidden curated landing page. Not in nav, not in sitemap, not Pagefind-
// indexed. Surfaces purchasing / sourcing / product-offering roles in
// fashion / beauty / perfume / home / textile / decoration / retail-
// luxury verticals, France or remote-EU.

const TARGET_INDUSTRIES = new Set([
  "fashion",
  "beauty",
  "perfume",
  "home",
  "interior-design",
  "decoration",
  "textile",
  "retail-luxury",
]);

// Buying / sourcing / product-offering roles in fashion/beauty/home,
// French + English. Permissive โ€” this is Camille's curated lane.
const ROLE_PATTERNS = [
  // FR โ€” explicit buying / sourcing / product
  /\bacheteur(?:s|ses)?\b/i,
  /\bacheteuse(?:s)?\b/i,
  /\bresponsable\s+(?:des\s+)?(?:achat|achats|sourcing|approvisionnement|gamme|offre|offres|produit|produits|collection|collections|categorie|catรฉgorie|category|merchandising)\b/i,
  /\b(?:directeur|directrice)\s+(?:des\s+)?(?:achat|achats|sourcing|produit|produits|merchandising|offre|offres|categorie|catรฉgorie|collection|category)\b/i,
  /\bchef(?:fe)?\s+(?:de|des)\s+(?:produit|produits|marche|marchรฉ|gamme|categorie|catรฉgorie|category|collection)\b/i,
  // EN โ€” explicit buying / sourcing / product
  /\b(?:senior|junior|head\s+of|chief|lead)?\s*(?:buyer|buying|purchaser|purchasing)\b/i,
  /\b(?:product|category|brand|merchandising|assortment|sourcing|procurement)\s+(?:manager|director|lead|head|specialist|coordinator)\b/i,
  /\b(?:head|director|chief)\s+of\s+(?:product|category|brand|merchandising|assortment|sourcing|procurement|buying|purchasing)\b/i,
  /\bmerchandiser\b/i,
  // Hybrid title patterns common in fashion (e.g. "Chef de produit junior fashion")
  /\bproduct\s+(?:manager|owner|lead)\b/i,
];

function matchesRole(title: string): boolean {
  return ROLE_PATTERNS.some((re) => re.test(title));
}

function isFranceOrRemoteEU(j, c) {
  const loc = (j.location || "").toLowerCase();
  if (j.remote_policy === "remote-eu") return true;
  if (j.remote_policy === "remote-global") return true;
  if (loc.includes("france") || loc.includes("paris") || loc.includes(", fr")) return true;
  if (c?.country === "FR") return true;
  return false;
}

const matches = jobs.filter((j) => {
  const c = companies[j.company_slug];
  if (!c) return false;
  // Must touch at least one target industry tag.
  const tags = (c as any).industry_tags || [];
  if (!tags.some((t: string) => TARGET_INDUSTRIES.has(t))) return false;
  // Must be France-located or remote-EU friendly.
  if (!isFranceOrRemoteEU(j, c)) return false;
  // Title must match the buyer/product role pattern.
  return matchesRole(j.title || "");
});

matches.sort((a, b) => (b.posted_at || "").localeCompare(a.posted_at || ""));

const now = Date.now();
const yearNow = new Date(now).getUTCFullYear();
function postedLabel(iso: string | null): string {
  if (!iso) return "";
  const t = new Date(iso).getTime();
  if (!isFinite(t) || t > now) return "";
  if (new Date(iso).getUTCFullYear() > yearNow) return "";
  const days = Math.floor((now - t) / 86400000);
  if (days <= 0) return "TODAY";
  if (days === 1) return "1D";
  if (days <= 7) return `${days}D`;
  if (days <= 31) return `${Math.round(days / 7)}W`;
  return `${Math.round(days / 30)}MO`;
}

// Coverage stats.
const targetCompanies = Object.values(companies).filter((c) =>
  ((c as any).industry_tags || []).some((t: string) => TARGET_INDUSTRIES.has(t)),
);
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---
<Base
  title="Camille โ€” curated buyer roles"
  description="Private curated landing page."
  noindex={true}
>
  <main class="camille-page" data-pagefind-ignore>
    <header class="camille-header">
      <p class="page-marker">
        Camille ยท {targetCompanies.length} brands ยท fashion / beauty / perfume / home
        ยท purchase + product-offering roles ยท France + Remote-EU
      </p>
      <h1 class="camille-h1">{matches.length.toLocaleString("en-US")} matching roles</h1>
    </header>

    {matches.length === 0 ? (
      <p class="empty">No matching roles in this snapshot. Refresh tomorrow โ€” the corpus updates daily.</p>
    ) : (
      <ol class="results-list">
        {matches.map((j) => {
          const c = companies[j.company_slug];
          const company = c?.name || j.company_slug;
          const loc = j.location || "";
          const posted = postedLabel(j.posted_at);
          return (
            <li class="result-item">
              <a href={`${base}jobs/${jobUrlPath(j)}/`} class="result-link">
                <span class="result-title">{j.title}</span>
                <span class="result-org">{company}{loc ? ` ยท ${loc}` : ""}</span>
                <span class="result-meta">{posted}</span>
              </a>
            </li>
          );
        })}
      </ol>
    )}

    <footer class="camille-foot">
      <p>
        Updates daily. Hidden URL โ€” not in site navigation or search. Industries
        covered (so far): {[...TARGET_INDUSTRIES].sort().join(", ")}.
      </p>
    </footer>
  </main>

  <style>
    .camille-page { max-width: 920px; padding-top: 32px; }
    .camille-header { margin: 0 0 32px; padding-bottom: 16px; border-bottom: 1px solid var(--ink); }
    .page-marker {
      font: 500 11px/1.6 var(--mono);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin: 0 0 12px;
    }
    .camille-h1 {
      font-family: var(--display);
      font-style: italic;
      font-size: 40px;
      line-height: 1.05;
      letter-spacing: -0.01em;
      font-weight: 400;
      margin: 0;
    }
    .empty { padding: 48px 0; text-align: center; color: var(--muted); }
    .camille-foot {
      margin-top: 48px;
      padding-top: 16px;
      border-top: 1px solid var(--rule);
      font: 500 11px/1.6 var(--mono);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
    }
  </style>
</Base>
