---
import Base from "../layouts/Base.astro";
import {
  jobsForFrontPage,
  jobsSorted,
  companies,
  PAGE_SIZE,
  formatDate,
  countryName,
  jobUrlPath,
  formatSalary,
  facetCounts,
} from "../lib/data";

const allJobs = jobsSorted();
const totalPages = Math.max(1, Math.ceil(allJobs.length / PAGE_SIZE));
const pageJobs = jobsForFrontPage();
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";

// Chip option lists. Where = countries + Remote tiers (sorted by count, drop
// "Other" which is the noise bucket). Role = full 13-family list, count-sorted.
const whereOptions = Object.entries(facetCounts.where || {})
  .filter(([k, n]) => n > 0 && k !== "Other")
  .sort((a, b) => b[1] - a[1])
  .slice(0, 25);
const ROLE_LABELS: Record<string, string> = {
  engineering: "Engineering",
  "ml-ai": "ML / AI",
  data: "Data",
  product: "Product",
  design: "Design",
  sales: "Sales",
  marketing: "Marketing",
  ops: "Ops",
  hr: "HR / Recruiting",
  support: "Support",
  finance: "Finance",
  legal: "Legal",
  research: "Research",
};
const roleOptions = Object.entries(facetCounts.role || {})
  .filter(([k, n]) => n > 0 && k in ROLE_LABELS)
  .sort((a, b) => b[1] - a[1]);

// Compute per-row meta data — including a NEW flag for ≤24h jobs.
const now = Date.now();
const dayAgo = now - 24 * 60 * 60 * 1000;
const yearNow = new Date(now).getUTCFullYear();

function metaFor(j) {
  const c = companies[j.company_slug];
  const country = c?.country ? countryName(c.country) : "";
  const company = c?.name || j.company_slug;
  const loc = j.location || country || "";
  let isNew = false;
  let postedLabel = "";
  if (j.posted_at) {
    const t = new Date(j.posted_at).getTime();
    const yr = new Date(j.posted_at).getUTCFullYear();
    if (isFinite(t) && t <= now && yr <= yearNow) {
      const days = Math.floor((now - t) / 86400000);
      isNew = days <= 1;
      postedLabel = days <= 0 ? "TODAY" : days === 1 ? "1D" : days <= 7 ? `${days}D` : days <= 31 ? `${Math.round(days / 7)}W` : `${Math.round(days / 30)}MO`;
    }
  }
  const remoteLabel =
    j.remote_policy === "remote-global" ? "REMOTE-WW"
    : j.remote_policy === "remote-eu" ? "REMOTE-EU"
    : j.remote_policy === "remote" ? "REMOTE"
    : j.remote_policy === "hybrid" ? "HYBRID"
    : "";
  const salary = formatSalary(j);
  const metaBits = [
    isNew ? `<span class="new">NEW</span>` : (postedLabel || ""),
    remoteLabel,
    salary ? `<span class="salary">${salary}</span>` : "",
  ].filter(Boolean);
  return { company, loc, metaBits: metaBits.join(" · ") };
}
---
<Base title="eu-tech-jobs — EU AI/Tech Jobs Wire">
  <main>
    <form action={`${base}search/`} method="get" role="search" id="home-search" class="home-search">
      <div class="search-input-wrap home-search-input">
        <input
          type="search"
          name="q"
          class="search-input"
          placeholder={`search ${allJobs.length.toLocaleString("en-US")} jobs…`}
          autocomplete="off"
          aria-label="Search jobs"
        />
      </div>
      {/* Hidden <select> is the source of truth for state and form-submission;
          chip-filter.js progressively enhances it into a chip-popover trigger.
          Submit takes the user to /search/ with the selections pre-applied. */}
      <select id="where" multiple class="chip-source" data-chip-label="Where" data-chip-group-prefix="Remote — " aria-label="Country and remote">
        {whereOptions.map(([name, n]) => (
          <option value={name} data-count={n}>{name}</option>
        ))}
      </select>
      <select id="role" multiple class="chip-source" data-chip-label="Role" aria-label="Role">
        {roleOptions.map(([k, n]) => (
          <option value={k} data-count={n}>{ROLE_LABELS[k]}</option>
        ))}
      </select>
      <select id="type" multiple class="chip-source" data-chip-label="Type" aria-label="Employment type">
        <option value="permanent">Permanent</option>
        <option value="freelance">Freelance</option>
        <option value="internship">Internship</option>
        <option value="apprenticeship">Apprenticeship</option>
      </select>
    </form>
    <script src={`${base}chip-filter.js`} defer></script>
    <script is:inline define:vars={{ base }}>
      // Submit handler funnels search input + chip selections into /search/
      // pre-loaded with filter[where][] / filter[role][] / filter[type][].
      (function () {
        const form = document.getElementById("home-search");
        if (!form) return;
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          const params = new URLSearchParams();
          const q = (form.querySelector('input[name="q"]')?.value || "").trim();
          if (q) params.set("q", q);
          for (const facet of ["where", "role", "type"]) {
            const sel = document.getElementById(facet);
            if (!sel) continue;
            for (const o of sel.selectedOptions) {
              params.append(`filter[${facet}][]`, o.value);
            }
          }
          location.href = `${base}search/${params.toString() ? "?" + params.toString() : ""}`;
        });
      })();
    </script>

    {pageJobs.length === 0 ? (
      <p class="empty">No jobs in this snapshot.</p>
    ) : (
      <>
        <ol class="results-list">
          {pageJobs.map((j) => {
            const m = metaFor(j);
            return (
              <li class="result-item">
                <a href={`${base}jobs/${jobUrlPath(j)}/`} class="result-link">
                  <span class="result-title">{j.title}</span>
                  <span class="result-org">{m.company}{m.loc ? ` · ${m.loc}` : ""}</span>
                  <span class="result-meta" set:html={m.metaBits}></span>
                </a>
              </li>
            );
          })}
        </ol>
        {totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination">
            <span class="current">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 9) }, (_, i) => i + 2).map((p) => (
              <a href={`${base}page/${p}/`}>{p}</a>
            ))}
            {totalPages > 10 && <span>…</span>}
            {totalPages > 10 && <a href={`${base}page/${totalPages}/`}>{totalPages}</a>}
          </nav>
        )}
      </>
    )}
  </main>
  <footer>
    <p>
      Open data · daily refresh ·
      {" "}<a href="https://github.com/Aramente/eu-tech-jobs">github</a> ·
      {" "}<a href="https://huggingface.co/datasets/Aramente/eu-tech-jobs">hugging face</a> ·
      {" "}<a href={`${base}feed.xml`}>rss</a> ·
      {" "}<a href="mailto:kevin.duchier@gmail.com">removal</a>
    </p>
  </footer>
</Base>
