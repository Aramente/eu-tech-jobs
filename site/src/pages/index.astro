---
import Base from "../layouts/Base.astro";
import { jobsSorted, companies, meta, PAGE_SIZE } from "../lib/data";

const allJobs = jobsSorted();
const totalPages = Math.max(1, Math.ceil(allJobs.length / PAGE_SIZE));
const pageJobs = allJobs.slice(0, PAGE_SIZE);

const companyCount = Object.keys(companies).length;
const runAt = meta.run_at ? new Date(meta.run_at).toISOString().slice(0, 10) : "—";
const successRate = meta.extractor_results
  ? Math.round(
      (meta.extractor_results.filter((r) => r.success).length /
        Math.max(meta.extractor_results.length, 1)) *
        100
    )
  : 100;

const countries = Array.from(
  new Set(Object.values(companies).map((c) => c.country).filter(Boolean))
).sort();

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---
<Base title="eu-tech-jobs — EU AI/Tech Jobboard">
  <header>
    <h1>eu-tech-jobs · EU AI/Tech Jobs</h1>
    <p class="lede">
      Daily-updated open-data feed. {allJobs.length.toLocaleString()} active jobs from
      {companyCount} companies.
    </p>
    <div class="stats">
      <span>Snapshot: <strong>{runAt}</strong></span>
      <span>Pipeline success: <strong>{successRate}%</strong></span>
      <span><a href={`${base}feed.xml`}>RSS</a></span>
      <span><a href={`${base}companies/`}>Companies</a></span>
      <span><a href={`${base}trends/`}>Trends</a></span>
      <span><a href={`${base}search/`}>Search</a></span>
      <span><a href="https://github.com/Aramente/eu-tech-jobs">GitHub</a></span>
      <span><a href="https://huggingface.co/datasets/Aramente/eu-tech-jobs">Dataset</a></span>
    </div>
  </header>
  <main>
    <p class="meta">
      <a href={`${base}search/`}>Full-text search →</a>
      (Pagefind index across all job descriptions, regenerated nightly)
    </p>
    <div class="filters">
      <input id="search" type="search" placeholder="Quick filter (this page)…" />
      <select id="country">
        <option value="">All countries</option>
        {countries.map((c) => <option value={c}>{c}</option>)}
      </select>
      <select id="role">
        <option value="">All roles</option>
        <option value="ml-ai">ML / AI</option>
        <option value="engineering">Engineering</option>
        <option value="data">Data</option>
        <option value="product">Product</option>
        <option value="design">Design</option>
        <option value="sales">Sales</option>
        <option value="marketing">Marketing</option>
        <option value="ops">Ops</option>
      </select>
    </div>
    {pageJobs.length === 0 ? (
      <p class="empty">No jobs in this snapshot.</p>
    ) : (
      <>
        <p class="meta">
          Showing first {pageJobs.length.toLocaleString()} of {allJobs.length.toLocaleString()}.
          {totalPages > 1 && <> <a href={`${base}page/2/`}>Next →</a></>}
        </p>
        <table id="jobs-table">
          <thead>
            <tr><th>Title</th><th>Company</th><th>Location</th><th>Posted</th></tr>
          </thead>
          <tbody>
            {pageJobs.map((j) => {
              const c = companies[j.company_slug];
              const country = c?.country || "";
              const name = c?.name || j.company_slug;
              return (
                <tr data-country={country} data-role={j.role_family || ""} data-haystack={`${j.title} ${name} ${j.location}`.toLowerCase()}>
                  <td><a href={`${base}jobs/${j.id}/`}>{j.title}</a></td>
                  <td class="company">
                    <a href={`${base}companies/${j.company_slug}/`}>{name}</a>{" "}
                    {country && <span class="badge">{country}</span>}
                  </td>
                  <td class="meta">{j.location || "—"}</td>
                  <td class="meta">{j.posted_at ? j.posted_at.slice(0, 10) : "—"}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {totalPages > 1 && (
          <nav class="pagination">
            <span class="current">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 9) }, (_, i) => i + 2).map((p) => (
              <a href={`${base}page/${p}/`}>{p}</a>
            ))}
            {totalPages > 10 && <span>…</span>}
            {totalPages > 10 && <a href={`${base}page/${totalPages}/`}>{totalPages}</a>}
          </nav>
        )}
      </>
    )}
  </main>
  <footer>
    <p>
      Code <a href="https://github.com/Aramente/eu-tech-jobs/blob/main/LICENSE">MIT</a>;
      data <a href="https://github.com/Aramente/eu-tech-jobs/blob/main/DATA_LICENSE">CC BY 4.0</a>.
      No LinkedIn / Indeed scraping. Removal:
      <a href="mailto:kevin.duchier@gmail.com">email</a>.
    </p>
  </footer>
  <script>
    const search = document.getElementById("search");
    const country = document.getElementById("country");
    const role = document.getElementById("role");
    const rows = Array.from(document.querySelectorAll("#jobs-table tbody tr"));
    function apply() {
      const q = (search?.value || "").toLowerCase().trim();
      const cc = (country)?.value || "";
      const rr = (role)?.value || "";
      for (const row of rows) {
        const r = row;
        const haystack = r.dataset.haystack || "";
        const c = r.dataset.country || "";
        const ro = r.dataset.role || "";
        const okQ = !q || haystack.includes(q);
        const okC = !cc || c === cc;
        const okR = !rr || ro === rr;
        r.style.display = okQ && okC && okR ? "" : "none";
      }
    }
    search?.addEventListener("input", apply);
    country?.addEventListener("change", apply);
    role?.addEventListener("change", apply);
  </script>
</Base>
