---
import Base from "../layouts/Base.astro";
import {
  jobsForFrontPage,
  jobsSorted,
  companies,
  PAGE_SIZE,
  formatDate,
  countryName,
  jobUrlPath,
} from "../lib/data";

const allJobs = jobsSorted();
const totalPages = Math.max(1, Math.ceil(allJobs.length / PAGE_SIZE));
const pageJobs = jobsForFrontPage();
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";

// Compute per-row meta data — including a NEW flag for ≤24h jobs.
const now = Date.now();
const dayAgo = now - 24 * 60 * 60 * 1000;
const yearNow = new Date(now).getUTCFullYear();

function metaFor(j) {
  const c = companies[j.company_slug];
  const country = c?.country ? countryName(c.country) : "";
  const company = c?.name || j.company_slug;
  const loc = j.location || country || "";
  let isNew = false;
  let postedLabel = "";
  if (j.posted_at) {
    const t = new Date(j.posted_at).getTime();
    const yr = new Date(j.posted_at).getUTCFullYear();
    if (isFinite(t) && t <= now && yr <= yearNow) {
      const days = Math.floor((now - t) / 86400000);
      isNew = days <= 1;
      postedLabel = days <= 0 ? "TODAY" : days === 1 ? "1D" : days <= 7 ? `${days}D` : days <= 31 ? `${Math.round(days / 7)}W` : `${Math.round(days / 30)}MO`;
    }
  }
  const remoteLabel =
    j.remote_policy === "remote-global" ? "REMOTE-WW"
    : j.remote_policy === "remote-eu" ? "REMOTE-EU"
    : j.remote_policy === "remote" ? "REMOTE"
    : j.remote_policy === "hybrid" ? "HYBRID"
    : "";
  const metaBits = [
    isNew ? `<span class="new">NEW</span>` : (postedLabel || ""),
    remoteLabel,
  ].filter(Boolean);
  return { company, loc, metaBits: metaBits.join(" · ") };
}
---
<Base title="eu-tech-jobs — EU AI/Tech Jobs Wire">
  <main>
    <div class="search-input-wrap" style="max-width:560px;margin-bottom:24px">
      <form action={`${base}search/`} method="get" role="search" id="home-search">
        <input
          type="search"
          name="q"
          class="search-input"
          placeholder={`search ${allJobs.length.toLocaleString()} jobs…`}
          autocomplete="off"
          aria-label="Search jobs"
        />
      </form>
    </div>

    {pageJobs.length === 0 ? (
      <p class="empty">No jobs in this snapshot.</p>
    ) : (
      <>
        <ol class="results-list">
          {pageJobs.map((j) => {
            const m = metaFor(j);
            return (
              <li class="result-item">
                <a href={`${base}jobs/${jobUrlPath(j)}/`} class="result-link">
                  <span class="result-title">{j.title}</span>
                  <span class="result-org">{m.company}{m.loc ? ` · ${m.loc}` : ""}</span>
                  <span class="result-meta" set:html={m.metaBits}></span>
                </a>
              </li>
            );
          })}
        </ol>
        {totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination">
            <span class="current">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 9) }, (_, i) => i + 2).map((p) => (
              <a href={`${base}page/${p}/`}>{p}</a>
            ))}
            {totalPages > 10 && <span>…</span>}
            {totalPages > 10 && <a href={`${base}page/${totalPages}/`}>{totalPages}</a>}
          </nav>
        )}
      </>
    )}
  </main>
  <footer>
    <p>
      Open data · daily refresh ·
      {" "}<a href="https://github.com/Aramente/eu-tech-jobs">github</a> ·
      {" "}<a href="https://huggingface.co/datasets/Aramente/eu-tech-jobs">hugging face</a> ·
      {" "}<a href={`${base}feed.xml`}>rss</a> ·
      {" "}<a href="mailto:kevin.duchier@gmail.com">removal</a>
    </p>
  </footer>
</Base>
