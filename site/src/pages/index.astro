---
import Base from "../layouts/Base.astro";
import {
  jobsSorted,
  jobsForFrontPage,
  companies,
  meta,
  PAGE_SIZE,
  formatDate,
  displayCountry,
  jobUrlPath,
  facetCounts,
} from "../lib/data";

const allJobs = jobsSorted();
const totalPages = Math.max(1, Math.ceil(allJobs.length / PAGE_SIZE));
const pageJobs = jobsForFrontPage();

const companyCount = Object.keys(companies).length;
const runAt = formatDate(meta.run_at);
const successRate = meta.extractor_results
  ? Math.round(
      (meta.extractor_results.filter((r) => r.success).length /
        Math.max(meta.extractor_results.length, 1)) *
        100
    )
  : 100;

const countries = Array.from(
  new Set(Object.values(companies).map((c) => c.country).filter(Boolean))
).sort();

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/";
---
<Base title="eu-tech-jobs — EU AI/Tech Jobboard">
  <header>
    <h1>eu-tech-jobs</h1>
    <p class="lede">
      <strong>{allJobs.length.toLocaleString()} EU AI/tech jobs</strong> from
      {companyCount} companies. Daily-updated open data. No LinkedIn or Indeed.
    </p>
    <div class="stats">
      <span>Updated <strong>{runAt}</strong></span>
      <span><a href={`${base}companies/`}>Companies</a></span>
      <span><a href={`${base}trends/`}>Trends</a></span>
      <span><a href={`${base}search/`}>Search</a></span>
      <span><a href="https://aramente.github.io/bored-cv/">Tailor a CV with Bored CV →</a></span>
    </div>
  </header>
  <main>
    <p class="meta" style="margin-bottom: 16px;">
      <strong>{pageJobs.length}</strong> freshest jobs below (max 5 per company on
      page 1 — keeps mass hirers from eating the front page). Quick-filter the
      visible 100 with the dropdowns; type to <a href={`${base}search/`}>full-text
      search all {allJobs.length.toLocaleString()} jobs</a> instead.
    </p>
    <form
      class="filters"
      role="search"
      onsubmit={`event.preventDefault(); const q = document.getElementById('search').value.trim(); if (q) location.href = '${base}search/?q=' + encodeURIComponent(q);`}
    >
      <input
        id="search"
        type="search"
        placeholder={`Search all ${allJobs.length.toLocaleString()} jobs (Enter) or filter this page…`}
      />
      <select id="country" data-facet="country">
        <option value="">All countries</option>
        {countries.map((c) => {
          const n = facetCounts.country[c] || 0;
          return (
            <option value={c} data-count={n}>
              {displayCountry(c)} ({n.toLocaleString()})
            </option>
          );
        })}
      </select>
      <select id="role" data-facet="role">
        <option value="">All roles</option>
        {[
          ["ml-ai", "ML / AI"],
          ["engineering", "Engineering"],
          ["data", "Data"],
          ["product", "Product"],
          ["design", "Design"],
          ["sales", "Sales"],
          ["marketing", "Marketing"],
          ["ops", "Ops"],
          ["hr", "HR / Recruiting"],
          ["finance", "Finance"],
          ["legal", "Legal"],
          ["research", "Research"],
          ["support", "Support"],
        ].map(([v, label]) => {
          const n = facetCounts.role[v] || 0;
          return n === 0 ? null : (
            <option value={v} data-count={n}>
              {label} ({n.toLocaleString()})
            </option>
          );
        })}
      </select>
    </form>
    <p id="filter-status" class="meta filter-status" data-base={base}>
      Showing 1–{pageJobs.length} of {allJobs.length.toLocaleString()} most recent
      · sorted by post date · paginated below.
    </p>
    {pageJobs.length === 0 ? (
      <p class="empty">No jobs in this snapshot.</p>
    ) : (
      <>
        <table id="jobs-table">
          <thead>
            <tr><th>Title</th><th>Company</th><th>Location</th><th>Posted</th></tr>
          </thead>
          <tbody>
            {pageJobs.map((j) => {
              const c = companies[j.company_slug];
              const country = c?.country || "";
              const name = c?.name || j.company_slug;
              return (
                <tr data-country={country} data-role={j.role_family || ""} data-haystack={`${j.title} ${name} ${j.location}`.toLowerCase()}>
                  <td><a href={`${base}jobs/${jobUrlPath(j)}/`}>{j.title}</a></td>
                  <td class="company">
                    <a href={`${base}companies/${j.company_slug}/`}>{name}</a>{" "}
                    {country && <span class="badge">{displayCountry(country)}</span>}
                  </td>
                  <td class="meta">{j.location || "—"}</td>
                  <td class="meta">{formatDate(j.posted_at)}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {totalPages > 1 && (
          <nav class="pagination">
            <span class="current">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 9) }, (_, i) => i + 2).map((p) => (
              <a href={`${base}page/${p}/`}>{p}</a>
            ))}
            {totalPages > 10 && <span>…</span>}
            {totalPages > 10 && <a href={`${base}page/${totalPages}/`}>{totalPages}</a>}
          </nav>
        )}
      </>
    )}
  </main>
  <footer>
    <p>
      <strong>For developers / researchers:</strong>{" "}
      <a href={`${base}feed.xml`}>RSS feed</a> ·{" "}
      <a href="https://github.com/Aramente/eu-tech-jobs">source on GitHub</a> (MIT) ·{" "}
      <a href="https://huggingface.co/datasets/Aramente/eu-tech-jobs">parquet dataset on Hugging Face</a> (CC BY 4.0) ·{" "}
      pipeline success {successRate}%.
    </p>
    <p>
      Removal requests: <a href="mailto:kevin.duchier@gmail.com">email</a>.
      We don't scrape LinkedIn or Indeed.
    </p>
  </footer>
  <script>
    const search = document.getElementById("search");
    const country = document.getElementById("country");
    const role = document.getElementById("role");
    const status = document.getElementById("filter-status");
    const base = status?.dataset.base || "/";
    const rows = Array.from(document.querySelectorAll("#jobs-table tbody tr"));
    const totalAll = rows.length ? null : 0; // populated via meta later
    function selectedCount(sel) {
      if (!sel || !sel.value) return null;
      const opt = sel.selectedOptions[0];
      const n = opt?.dataset.count;
      return n == null ? null : Number(n);
    }
    function apply() {
      const q = (search?.value || "").toLowerCase().trim();
      const cc = (country)?.value || "";
      const rr = (role)?.value || "";
      let visible = 0;
      for (const row of rows) {
        const haystack = row.dataset.haystack || "";
        const c = row.dataset.country || "";
        const ro = row.dataset.role || "";
        const okQ = !q || haystack.includes(q);
        const okC = !cc || c === cc;
        const okR = !rr || ro === rr;
        const show = okQ && okC && okR;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      // Update the count line + escalation link.
      if (!status) return;
      const anyFilter = q || cc || rr;
      if (!anyFilter) {
        status.innerHTML = `Showing 1–${rows.length} of ${rows.length} most recent · sorted by post date · paginated below.`;
        return;
      }
      const countryN = selectedCount(country);
      const roleN = selectedCount(role);
      const parts = [];
      if (cc) parts.push(`<strong>${countryN?.toLocaleString() ?? "?"}</strong> in ${country.selectedOptions[0].textContent.replace(/\s*\(.*$/, "")}`);
      if (rr) parts.push(`<strong>${roleN?.toLocaleString() ?? "?"}</strong> in ${role.selectedOptions[0].textContent.replace(/\s*\(.*$/, "")}`);
      const params = new URLSearchParams();
      if (q) params.set("q", q);
      // Pagefind filter param shape: filter[where]=value (we don't have country->where mapping client-side; use role + free text)
      if (rr) params.set("filter[role]", rr);
      const searchUrl = `${base}search/${params.toString() ? "?" + params.toString() : ""}`;
      const globalLine = parts.length
        ? ` · across all ${rows.length.toLocaleString()}+ jobs: ${parts.join(" · ")}`
        : "";
      status.innerHTML =
        `Visible on this page: <strong>${visible}</strong> of ${rows.length}` +
        globalLine +
        ` · <a href="${searchUrl}">See all matching at /search/ →</a>`;
    }
    search?.addEventListener("input", apply);
    country?.addEventListener("change", apply);
    role?.addEventListener("change", apply);
  </script>
</Base>
